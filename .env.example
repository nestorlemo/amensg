DATABASE_URL="postgresql://postgres:postgres@postgres:5432/amensg?schema=public&pool_timeout=30"
# With PgBouncer (transaction pooling), append: ?pgbouncer=true&prepared_statements=false
# DATABASE_URL="postgresql://user:pass@host:5432/amensg?schema=public&pgbouncer=true&prepared_statements=false"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=amensg
NEXTAUTH_SECRET=change_me
JWT_SECRET=change_me_optional
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@amensg.local
ADMIN_PASSWORD=change_me_secure
STORAGE_DRIVER=local
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_MB=20
