generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id           String      @id @default(uuid()) @db.Uuid
  nombre       String
  email        String      @unique
  passwordHash String
  rol          String      @default("OPERADOR")
  activo       Boolean     @default(true)
  creadoEn     DateTime    @default(now())
  actualizadoEn DateTime   @updatedAt
  auditorias   Auditoria[]
}

model Empresa {
  id              String                 @id @default(uuid()) @db.Uuid
  nombre          String                 @unique
  razonSocial     String?
  rut             String?
  direccion       String?
  contacto        String?
  mail            String?
  telefono        String?
  activa          Boolean                @default(true)
  creadaEn        DateTime               @default(now())
  activaciones    ActivacionImportada[]
  facturaciones   FacturacionMensual[]
  ingresosAdicionales IngresoAdicional[]
  cierresSocio    CierreSocio[]
  issues          Issue[]
  facturasDesarrollo FacturaDesarrollo[]
}

model Socio {
  id           String         @id @default(uuid()) @db.Uuid
  nombre       String
  porcentajeParticipacion Decimal @default(0) @db.Decimal(9, 6)
  cuentas      Json?
  activo       Boolean        @default(true)
  creadoEn     DateTime       @default(now())
  cierresSocio CierreSocio[]
  distribuciones DistribucionFactura[]
}

model Parametro {
  id          String   @id @default(uuid()) @db.Uuid
  clave       String   @unique
  valor       Decimal  @db.Decimal(18, 6)
  tipo        String   @default("DECIMAL")
  descripcion String?
  activo      Boolean  @default(true)
  actualizado DateTime @updatedAt
}

model EstadoCobro {
  id             String                @id @default(uuid()) @db.Uuid
  codigo         String                @unique
  nombre         String
  facturaciones  FacturacionMensual[]
}

model ImportacionActivacion {
  id                   String                 @id @default(uuid()) @db.Uuid
  anio                 Int
  mes                  Int
  nombreArchivo        String?
  hashArchivo          String                 @unique
  estado               String                 @default("ACTIVA")
  anuladaEn            DateTime?
  motivoAnulacion      String?
  creadaEn             DateTime               @default(now())
  activaciones         ActivacionImportada[]
  facturaciones        FacturacionMensual[]
  @@index([anio, mes])
}

model ActivacionImportada {
  id                   String                 @id @default(uuid()) @db.Uuid
  importacionId        String                 @db.Uuid
  empresaId            String                 @db.Uuid
  anio                 Int
  mes                  Int
  mid                  String
  chip                 String
  empresaNombreArchivo String
  estadoActivacion     String
  lote                 String
  fechaImportacion     DateTime
  fechaActivacion      DateTime?
  tieneFechaRealActivacion Boolean            @default(false)
  monto                Decimal                @db.Decimal(18, 2)
  rawRowJson           Json
  creadaEn             DateTime               @default(now())
  importacion          ImportacionActivacion  @relation(fields: [importacionId], references: [id])
  empresa              Empresa                @relation(fields: [empresaId], references: [id])

  @@index([empresaId, anio, mes, mid])
  @@index([empresaId, anio, mes, chip])
  @@index([importacionId])
}

model FacturacionMensual {
  id             String   @id @default(uuid()) @db.Uuid
  importacionId  String   @db.Uuid
  empresaId      String   @db.Uuid
  estadoCobroId  String   @db.Uuid
  anio           Int
  mes            Int
  cantidadActivaciones Int
  precioUnitario Decimal  @db.Decimal(18, 2)
  porcentajeIva  Decimal  @db.Decimal(18, 6)
  totalSinIva    Decimal  @db.Decimal(18, 2)
  iva            Decimal  @db.Decimal(18, 2)
  totalConIva    Decimal  @db.Decimal(18, 2)
  fechaCobro     DateTime?
  observaciones  String?
  snapshot       Json?
  creadaEn       DateTime @default(now())
  importacion    ImportacionActivacion @relation(fields: [importacionId], references: [id])
  empresa        Empresa  @relation(fields: [empresaId], references: [id])
  estadoCobro    EstadoCobro @relation(fields: [estadoCobroId], references: [id])

  @@index([empresaId, anio, mes])
  @@index([importacionId])
  @@index([estadoCobroId])
}

model GastoConcepto {
  id       String         @id @default(uuid()) @db.Uuid
  nombre   String
  tipo     String         @default("VARIABLE")
  monto    Decimal?       @db.Decimal(12, 2)
  activo   Boolean        @default(true)
  creadoEn DateTime       @default(now())
  gastos   GastoMensual[]
}

model GastoMensual {
  id         String        @id @default(uuid()) @db.Uuid
  conceptoId String        @db.Uuid
  anio       Int
  mes        Int
  fecha      DateTime
  importe    Decimal       @db.Decimal(18, 2)
  observaciones String?
  concepto   GastoConcepto @relation(fields: [conceptoId], references: [id])

  @@index([conceptoId])
  @@index([anio, mes])
}

model IngresoAdicional {
  id          String   @id @default(uuid()) @db.Uuid
  concepto    String
  empresaId   String?  @db.Uuid
  anio        Int
  mes         Int
  moneda      String   @default("UYU")
  montoOrigen Decimal  @db.Decimal(18, 2)
  fechaFacturacion DateTime
  tipoCambioAplicado Decimal? @db.Decimal(18, 6)
  fuenteTipoCambio String?
  fechaTipoCambio DateTime?
  montoSinIva Decimal  @db.Decimal(18, 2)
  porcentajeIva Decimal @db.Decimal(18, 6)
  iva         Decimal  @db.Decimal(18, 2)
  montoConIva Decimal  @db.Decimal(18, 2)
  observaciones String?
  creadoEn    DateTime @default(now())
  empresa     Empresa? @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
  @@index([anio, mes])
}

model CierreMensual {
  id            String        @id @default(uuid()) @db.Uuid
  anio          Int
  mes           Int
  estado        String        @default("CERRADO")
  cerradoAt     DateTime?
  reabiertoAt   DateTime?
  reabiertoPor  String?
  motivoReapertura String?
  snapshot      Json
  creadoEn      DateTime      @default(now())
  cierresSocio  CierreSocio[]

  @@unique([anio, mes])
}

model CierreSocio {
  id              String         @id @default(uuid()) @db.Uuid
  cierreMensualId String         @db.Uuid
  socioId         String         @db.Uuid
  empresaId       String?        @db.Uuid
  snapshot        Json
  cierreMensual   CierreMensual  @relation(fields: [cierreMensualId], references: [id])
  socio           Socio          @relation(fields: [socioId], references: [id])
  empresa         Empresa?       @relation(fields: [empresaId], references: [id])

  @@unique([cierreMensualId, socioId, empresaId])
}

model Issue {
  id                String    @id @default(uuid()) @db.Uuid
  fecha             DateTime
  descripcion       String
  horasDesarrollo   Decimal   @db.Decimal(8, 2)
  horasTest         Decimal   @default(0) @db.Decimal(8, 2)
  horasRework       Decimal   @default(0) @db.Decimal(8, 2)
  totalHoras        Decimal   @db.Decimal(8, 2)
  estado            String
  fechaProduccion   DateTime?
  motivoCancelacion String?
  reportadoPor      String
  prioridad         String
  empresaId         String?   @db.Uuid
  empresa           Empresa?  @relation(fields: [empresaId], references: [id])
  facturaIssues     FacturaIssue[]
  creadoEn          DateTime  @default(now())
  actualizadoEn     DateTime  @updatedAt

  @@index([empresaId])
  @@index([estado])
  @@index([fecha])
}

model ValorHoraDesarrollo {
  id            String   @id @default(uuid()) @db.Uuid
  valorUSD      Decimal  @db.Decimal(10, 2)
  vigenciaDesde DateTime
  creadoEn      DateTime @default(now())
}

model FacturaDesarrollo {
  id                 String   @id @default(uuid()) @db.Uuid
  anio               Int
  mes                Int
  empresaId          String   @db.Uuid
  empresa            Empresa  @relation(fields: [empresaId], references: [id])
  totalHoras         Decimal  @db.Decimal(8, 2)
  valorHoraUSD       Decimal  @db.Decimal(10, 2)
  totalUSD           Decimal  @db.Decimal(12, 2)
  tipoCambio         Decimal  @db.Decimal(10, 2)
  totalUYU           Decimal  @db.Decimal(12, 2)
  iva                Decimal  @db.Decimal(12, 2)
  totalConIva        Decimal  @db.Decimal(12, 2)
  distribuciones     DistribucionFactura[]
  facturaIssues      FacturaIssue[]
  ingresoAdicionalId String?  @db.Uuid
  estado             String   @default("PENDIENTE") // PENDIENTE | COBRADO
  creadoEn           DateTime @default(now())

  @@index([empresaId, anio, mes])
}

model FacturaIssue {
  facturaId String            @db.Uuid
  issueId   String            @db.Uuid
  factura   FacturaDesarrollo @relation(fields: [facturaId], references: [id])
  issue     Issue             @relation(fields: [issueId], references: [id])

  @@id([facturaId, issueId])
}

model DistribucionFactura {
  id        String            @id @default(uuid()) @db.Uuid
  facturaId String            @db.Uuid
  factura   FacturaDesarrollo @relation(fields: [facturaId], references: [id])
  socioId   String            @db.Uuid
  socio     Socio             @relation(fields: [socioId], references: [id])
  porcentaje Decimal          @db.Decimal(5, 2)
  montoUYU  Decimal           @db.Decimal(12, 2)

  @@index([facturaId])
}

model Auditoria {
  id        String   @id @default(uuid()) @db.Uuid
  usuarioId String?  @db.Uuid
  entidad   String
  entidadId String
  accion    String
  detalle   Json?
  creadoEn  DateTime @default(now())
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])
}
