generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id           String      @id @default(uuid()) @db.Uuid
  nombre       String
  email        String      @unique
  passwordHash String
  activo       Boolean     @default(true)
  creadoEn     DateTime    @default(now())
  auditorias   Auditoria[]
}

model Empresa {
  id              String                 @id @default(uuid()) @db.Uuid
  nombre          String
  activa          Boolean                @default(true)
  creadaEn        DateTime               @default(now())
  importaciones   ImportacionActivacion[]
  activaciones    ActivacionImportada[]
  facturaciones   FacturacionMensual[]
  cierresSocio    CierreSocio[]
}

model Socio {
  id           String         @id @default(uuid()) @db.Uuid
  nombre       String
  activo       Boolean        @default(true)
  creadoEn     DateTime       @default(now())
  cierresSocio CierreSocio[]
}

model Parametro {
  id          String   @id @default(uuid()) @db.Uuid
  clave       String   @unique
  valor       Decimal  @db.Decimal(18, 6)
  descripcion String?
  actualizado DateTime @updatedAt
}

model EstadoCobro {
  id     String @id @default(uuid()) @db.Uuid
  codigo String @unique
  nombre String
}

model ImportacionActivacion {
  id                   String                 @id @default(uuid()) @db.Uuid
  empresaId            String                 @db.Uuid
  anio                 Int
  mes                  Int
  nombreArchivo        String?
  estado               String                 @default("ACTIVA")
  anuladaEn            DateTime?
  creadaEn             DateTime               @default(now())
  empresa              Empresa                @relation(fields: [empresaId], references: [id])
  activaciones         ActivacionImportada[]

  @@index([empresaId, anio, mes])
}

model ActivacionImportada {
  id                   String                 @id @default(uuid()) @db.Uuid
  importacionId        String                 @db.Uuid
  empresaId            String                 @db.Uuid
  anio                 Int
  mes                  Int
  mid                  String
  chip                 String
  empresaNombreArchivo String
  monto                Decimal                @db.Decimal(18, 2)
  rawRowJson           Json
  creadaEn             DateTime               @default(now())
  importacion          ImportacionActivacion  @relation(fields: [importacionId], references: [id])
  empresa              Empresa                @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, anio, mes, mid])
  @@unique([empresaId, anio, mes, chip])
  @@index([importacionId])
}

model FacturacionMensual {
  id             String   @id @default(uuid()) @db.Uuid
  empresaId      String   @db.Uuid
  anio           Int
  mes            Int
  precioUnitario Decimal  @db.Decimal(18, 2)
  porcentajeIva  Decimal  @db.Decimal(18, 6)
  subtotal       Decimal  @db.Decimal(18, 2)
  iva            Decimal  @db.Decimal(18, 2)
  total          Decimal  @db.Decimal(18, 2)
  snapshot       Json?
  creadaEn       DateTime @default(now())
  empresa        Empresa  @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, anio, mes])
}

model GastoConcepto {
  id      String         @id @default(uuid()) @db.Uuid
  nombre  String         @unique
  activo  Boolean        @default(true)
  gastos  GastoMensual[]
}

model GastoMensual {
  id         String        @id @default(uuid()) @db.Uuid
  conceptoId String        @db.Uuid
  anio       Int
  mes        Int
  monto      Decimal       @db.Decimal(18, 2)
  concepto   GastoConcepto @relation(fields: [conceptoId], references: [id])
}

model IngresoAdicional {
  id          String   @id @default(uuid()) @db.Uuid
  descripcion String
  anio        Int
  mes         Int
  monto       Decimal  @db.Decimal(18, 2)
  creadoEn    DateTime @default(now())
}

model CierreMensual {
  id            String        @id @default(uuid()) @db.Uuid
  anio          Int
  mes           Int
  snapshot      Json
  creadoEn      DateTime      @default(now())
  cierresSocio  CierreSocio[]

  @@unique([anio, mes])
}

model CierreSocio {
  id              String         @id @default(uuid()) @db.Uuid
  cierreMensualId String         @db.Uuid
  socioId         String         @db.Uuid
  empresaId       String?        @db.Uuid
  snapshot        Json
  cierreMensual   CierreMensual  @relation(fields: [cierreMensualId], references: [id])
  socio           Socio          @relation(fields: [socioId], references: [id])
  empresa         Empresa?       @relation(fields: [empresaId], references: [id])

  @@unique([cierreMensualId, socioId, empresaId])
}

model Auditoria {
  id        String   @id @default(uuid()) @db.Uuid
  usuarioId String?  @db.Uuid
  entidad   String
  entidadId String
  accion    String
  detalle   Json?
  creadoEn  DateTime @default(now())
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])
}
